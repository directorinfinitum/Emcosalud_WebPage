---
import Icon from '@/components/icons/Icon.astro';
import type { IconName } from '@/data/icons';
import { site } from '@/data/site';

interface Props {
  size?: number;
  class?: string;
}

const { size = 18, class: className = '' } = Astro.props;

const networks: { href: string; label: string; icon: IconName }[] = [
  { href: site.social.facebook, label: 'Facebook', icon: 'facebook' },
  { href: site.social.instagram, label: 'Instagram', icon: 'instagram' },
  { href: site.social.youtube, label: 'YouTube', icon: 'youtube' },
  { href: site.social.whatsapp, label: 'WhatsApp', icon: 'whatsapp' },
];
---

<div class:list={['flex items-center gap-3', className]}>
  {
    networks.map((network) => (
      <a
        href={network.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={network.label}
      >
        <Icon name={network.icon} size={size} class="icon--social" />
      </a>
    ))
  }
</div>
