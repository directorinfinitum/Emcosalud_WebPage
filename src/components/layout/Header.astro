---
import Logo from '@/components/brand/Logo.astro';
import Icon from '@/components/icons/Icon.astro';
import SocialLinks from '@/components/layout/SocialLinks.astro';
import MobileMenu from '@/components/react/MobileMenu';
import { mainNavigation } from '@/data/navigation';
import { site } from '@/data/site';
---

<header class="sticky top-0 z-30 shadow-brand-sm">
  <div class="bg-brand-blue-dark text-sm text-white">
    <div class="container-page flex flex-wrap items-center justify-between gap-2 py-1.5">
      <p class="m-0 flex flex-wrap gap-4">
        <a
          href={`tel:${site.phones.huila.tel}`}
          class="inline-flex items-center gap-1.5 text-white no-underline transition hover:text-brand-green-light"
        >
          <Icon name="phone" size={14} />
          Huila: {site.phones.huila.label}
        </a>
        <a
          href={`tel:${site.phones.tolima.tel}`}
          class="inline-flex items-center gap-1.5 text-white no-underline transition hover:text-brand-green-light"
        >
          <Icon name="phone" size={14} />
          Tolima: {site.phones.tolima.label}
        </a>
      </p>
      <SocialLinks
        class="gap-4 sm:gap-5 [&_a]:inline-flex [&_a]:h-8 [&_a]:w-8 [&_a]:items-center [&_a]:justify-center [&_a]:rounded-full [&_a]:bg-white/10 [&_a]:text-white [&_a]:no-underline [&_a]:transition [&_a:hover]:bg-brand-green [&_a:hover]:text-brand-blue-dark"
        size={18}
      />
    </div>
  </div>

  <div class="border-b border-slate-200 bg-white text-brand-blue">
    <div class="container-page flex min-h-[4.5rem] items-center justify-between gap-4">
      <Logo variant="header" showTagline={false} />

      <nav class="hidden lg:block" aria-label="Menú principal">
        <ul class="m-0 flex list-none gap-1 p-0">
          {
            mainNavigation.map((item) =>
              item.children ? (
                <li class="group relative">
                  <button
                    type="button"
                    class="cursor-pointer rounded-md border-0 bg-transparent px-3 py-2 font-semibold text-brand-blue transition hover:bg-brand-green/10 hover:text-brand-green-dark"
                  >
                    {item.label}
                  </button>
                  <ul class="invisible absolute left-0 top-full z-20 m-0 min-w-[14rem] translate-y-1 list-none rounded-xl border border-slate-200 bg-white p-2 opacity-0 shadow-brand transition group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          target={child.external ? '_blank' : undefined}
                          rel={child.external ? 'noopener noreferrer' : undefined}
                          class="flex items-center gap-1.5 rounded-lg px-4 py-2 text-sm font-medium text-brand-blue no-underline hover:bg-brand-green/10 hover:text-brand-green-dark"
                        >
                          {child.label}
                          {child.external && <Icon name="external" size={14} class="opacity-60" />}
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li>
                  <a
                    href={item.href}
                    class="block rounded-md px-3 py-2 font-semibold text-brand-blue no-underline transition hover:bg-brand-green/10 hover:text-brand-green-dark"
                  >
                    {item.label}
                  </a>
                </li>
              ),
            )
          }
        </ul>
      </nav>

      <div class="flex items-center gap-3">
        <a class="btn btn--primary hidden text-sm lg:inline-flex" href="/citas">
          <Icon name="calendar" size={18} />
          Solicitar cita
        </a>
        <div class="lg:hidden">
          <MobileMenu client:load items={mainNavigation} />
        </div>
      </div>
    </div>
  </div>
</header>
