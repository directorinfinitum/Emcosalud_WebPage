---
import Icon from '@/components/icons/Icon.astro';
import CitasRequestForm from '@/components/react/CitasRequestForm';
import type { CitasDepartment } from '@/data/citas';
import {
  citasCytologyRecommendations,
  citasDirectAccessServices,
  citasFomagNote,
  citasGrowthDevelopmentAges,
  citasNursingServices,
  citasReminders,
  citasRequestNotice,
} from '@/data/citas';

interface Props {
  department: CitasDepartment;
}

const { department } = Astro.props;
const departmentLabel = department === 'huila' ? 'Huila' : 'Tolima';

const scheduleHighlights = [
  {
    icon: 'clock' as const,
    title: 'Horario de atención',
    text: 'Lunes a viernes, 7:00 a.m. – 12:00 m. y 2:00 p.m. – 4:00 p.m.',
  },
  {
    icon: 'users' as const,
    title: 'Orden de llegada',
    text: 'Las solicitudes se atienden en estricto orden de llegada.',
  },
  {
    icon: 'mail' as const,
    title: 'Respuesta por correo',
    text: 'Revise su bandeja de entrada y la carpeta de spam.',
  },
];
---

<div class="container-page max-w-6xl">
  <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,26rem)] lg:items-start lg:gap-12">
    <!-- Columna izquierda: información -->
    <div class="space-y-6">
      <div class="rounded-2xl border border-brand-blue/15 bg-gradient-to-br from-brand-blue/5 to-brand-green/5 p-5 md:p-6">
        <div class="mb-4 flex items-start gap-3">
          <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-blue text-white">
            <Icon name="shield-check" size={20} />
          </span>
          <div>
            <h2 class="m-0 text-lg font-bold text-brand-blue md:text-xl">
              {citasRequestNotice.title}
            </h2>
            <p class="mt-1 text-sm font-semibold text-brand-green-dark">
              {citasRequestNotice.subtitle}
            </p>
          </div>
        </div>
        <p class="m-0 text-sm leading-relaxed text-slate-700 md:text-base">
          {citasRequestNotice.paragraphs[0]}
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-3">
        {
          scheduleHighlights.map((item) => (
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-brand-sm">
              <p class="m-0 flex items-center gap-2 text-sm font-bold text-brand-blue">
                <Icon name={item.icon} size={18} class="text-brand-green" />
                {item.title}
              </p>
              <p class="mt-2 m-0 text-xs leading-relaxed text-slate-600">{item.text}</p>
            </div>
          ))
        }
      </div>

      <div
        class="flex gap-3 rounded-xl border border-amber-300 bg-amber-50 px-4 py-4 shadow-sm"
        role="alert"
      >
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-amber-200/80 text-amber-900">
          <Icon name="mail" size={18} />
        </span>
        <div>
          <p class="m-0 text-xs font-bold uppercase tracking-wide text-amber-900">Importante</p>
          <p class="mt-1.5 m-0 text-sm leading-relaxed text-amber-950">
            {citasRequestNotice.paragraphs[2]}
          </p>
        </div>
      </div>

      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-brand-sm md:p-6">
        <h2 class="m-0 text-lg font-bold text-brand-blue md:text-xl">
          Servicios de acceso directo
        </h2>
        <p class="mt-3 mb-4 text-sm leading-relaxed text-slate-600">
          Para estos servicios <strong class="text-brand-blue">no debes adjuntar</strong> historia
          clínica ni orden médica:
        </p>
        <ul class="m-0 flex list-none flex-wrap gap-2 p-0">
          {
            citasDirectAccessServices[department].map((service) => (
              <li class="rounded-full border border-brand-green/30 bg-brand-green/10 px-3 py-1.5 text-xs font-semibold text-brand-blue-dark">
                {service}
              </li>
            ))
          }
        </ul>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-5 md:p-6">
        <div class="mb-4 flex items-center gap-2">
          <Icon name="heart-pulse" size={20} class="text-brand-green" />
          <h3 class="m-0 text-base font-bold text-brand-blue">Servicios de enfermería</h3>
        </div>
        <ul class="m-0 space-y-2 p-0">
          {
            citasNursingServices.map((service) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-700">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-green" />
                {service}
              </li>
            ))
          }
        </ul>
      </article>

      <div class="grid gap-4 md:grid-cols-2">
        <article class="rounded-2xl border border-amber-200/80 bg-amber-50/60 p-5">
          <h3 class="m-0 text-sm font-bold text-amber-900">
            Citología y prueba ADN VPH
          </h3>
          <ul class="mt-3 m-0 space-y-2 p-0">
            {
              citasCytologyRecommendations.map((item) => (
                <li class="flex items-start gap-2 text-xs leading-relaxed text-amber-950/90">
                  <Icon name="shield-check" size={14} class="mt-0.5 shrink-0 text-amber-700" />
                  {item}
                </li>
              ))
            }
          </ul>
        </article>

        <article class="rounded-2xl border border-slate-200 bg-white p-5">
          <h3 class="m-0 text-sm font-bold text-brand-blue">Curso de vida</h3>
          <ul class="mt-3 m-0 space-y-2 p-0">
            {
              citasGrowthDevelopmentAges.map((item) => (
                <li class="flex items-start gap-2 text-xs leading-relaxed text-slate-700">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-blue" />
                  {item}
                </li>
              ))
            }
          </ul>
        </article>
      </div>

      <article class="rounded-2xl border border-brand-green/20 bg-brand-green/5 p-5">
        <h3 class="m-0 text-sm font-bold text-brand-blue">Ten en cuenta</h3>
        <ul class="mt-3 m-0 space-y-2 p-0">
          {
            citasReminders.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-700">
                <Icon name="shield-check" size={16} class="mt-0.5 shrink-0 text-brand-green-dark" />
                {item}
              </li>
            ))
          }
        </ul>
      </article>

      <p class="m-0 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-xs leading-relaxed text-slate-600">
        {citasFomagNote}
      </p>

      <p class="m-0 text-center text-sm font-semibold text-brand-blue lg:text-left">
        ¡Gracias por utilizar nuestros servicios! — Emcosalud Líderes en Salud
      </p>
    </div>

    <!-- Columna derecha: formulario -->
    <aside class="lg:sticky lg:top-24">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-brand md:p-6">
        <div class="mb-5 border-b border-slate-100 pb-4">
          <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-brand-green-dark">
            Formulario en línea
          </p>
          <h2 class="m-0 text-xl font-bold text-brand-blue">Solicitar cita — {departmentLabel}</h2>
          <p class="mt-2 m-0 text-sm leading-relaxed text-slate-600">
            Completa tus datos. La respuesta llegará al correo electrónico indicado en días hábiles.
          </p>
        </div>
        <CitasRequestForm client:load department={department} />
      </div>
    </aside>
  </div>
</div>
