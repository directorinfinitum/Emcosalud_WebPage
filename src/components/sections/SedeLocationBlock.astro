---
import Icon from '@/components/icons/Icon.astro';
import type { SedeLocation } from '@/data/sedes';

type Props = {
  location: SedeLocation;
};

const { location } = Astro.props;
const hasPlace = Boolean(location.image || location.mapEmbedUrl);
---

<article class="space-y-8">
  <h2 class="section-title m-0 text-center text-2xl md:text-3xl">{location.name}</h2>

  {
    hasPlace && (
      <div class="grid items-start gap-8 lg:grid-cols-2 lg:gap-10">
        {location.image && (
          <div class="overflow-hidden rounded-3xl border border-slate-200 shadow-brand">
            <img
              src={location.image}
              alt={location.imageAlt ?? location.name}
              width={684}
              height={1024}
              class="h-full max-h-[32rem] w-full object-cover object-center"
              loading="lazy"
            />
          </div>
        )}

        <div class="space-y-5">
          {location.mapEmbedUrl && (
            <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-brand-sm">
              <iframe
                src={location.mapEmbedUrl}
                title={location.address ?? `Ubicación ${location.name}`}
                class="block h-56 w-full border-0 md:h-64"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              />
            </div>
          )}

          {location.address && (
            <p class="m-0 text-sm text-slate-600">
              {location.mapsHref ? (
                <a
                  href={location.mapsHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-start gap-2 font-medium text-brand-blue no-underline hover:text-brand-green-dark"
                >
                  <Icon name="location" size={18} class="mt-0.5 shrink-0" />
                  {location.address}
                </a>
              ) : (
                <span class="inline-flex items-start gap-2">
                  <Icon name="location" size={18} class="mt-0.5 shrink-0 text-brand-blue" />
                  {location.address}
                </span>
              )}
            </p>
          )}

          {location.contacts.length > 0 && (
            <ul class="m-0 list-disc space-y-2 pl-5 text-sm text-slate-700">
              {location.contacts.map((c) => (
                <li>
                  <span class="font-semibold text-brand-blue">{c.label}: </span>
                  {c.href ? (
                    <a href={c.href} class="text-brand-blue no-underline hover:text-brand-green-dark">
                      {c.value}
                    </a>
                  ) : (
                    c.value
                  )}
                </li>
              ))}
            </ul>
          )}

          {(location.whatsappHref || location.appointmentHref) && (
            <div class="flex flex-wrap gap-3 pt-1">
              {location.whatsappHref && (
                <a
                  href={location.whatsappHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn inline-flex rounded-full border-brand-green bg-brand-green px-6 text-sm font-bold uppercase tracking-wide text-brand-blue-dark no-underline hover:bg-brand-green-light"
                >
                  <Icon name="whatsapp" size={20} />
                  Agenda tu cita
                </a>
              )}
              {location.appointmentHref && (
                <a
                  href={location.appointmentHref}
                  class="btn btn--primary inline-flex rounded-full px-6 text-sm no-underline"
                >
                  <Icon name="calendar" size={18} />
                  Solicitar cita
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    )
  }

  {!hasPlace && location.contacts.length > 0 && (
    <div class="card-base">
      <ul class="m-0 list-none space-y-2 p-0">
        {location.contacts.map((c) => (
          <li class="text-sm text-slate-700">
            <span class="font-semibold text-brand-blue">{c.label}: </span>
            {c.href ? (
              <a href={c.href} class="text-brand-blue no-underline hover:text-brand-green-dark">
                {c.value}
              </a>
            ) : (
              c.value
            )}
          </li>
        ))}
      </ul>
    </div>
  )}

  {location.schedules && location.schedules.length > 0 && (
    <div class="grid gap-6 border-t border-slate-200 pt-8 sm:grid-cols-2 lg:grid-cols-3">
      {location.schedules.map((block) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h3 class="m-0 text-sm font-bold uppercase tracking-wide text-brand-blue">
            {block.title}
          </h3>
          <ul class="mt-3 m-0 list-none space-y-2 p-0 text-sm text-slate-600">
            {block.lines.map((line) => (
              <li class="flex gap-2">
                <Icon name="clock" size={16} class="mt-0.5 shrink-0 text-brand-green" />
                {line}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  )}
</article>
