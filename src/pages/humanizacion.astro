---
import Icon from '@/components/icons/Icon.astro';
import AtencionUsuarioHero from '@/components/sections/AtencionUsuarioHero.astro';
import { humanizacionContent } from '@/data/atencion-usuario';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Humanización" description={humanizacionContent.description}>
  <AtencionUsuarioHero title={humanizacionContent.title} lead={humanizacionContent.description} />

  <section class="section-block bg-white">
    <div class="container-page flex flex-col items-center">
      <figure class="m-0 w-full max-w-[724px] overflow-hidden rounded-2xl border border-slate-200 shadow-brand-sm">
        <img
          src={humanizacionContent.image}
          alt={humanizacionContent.imageAlt}
          class="mx-auto block w-full"
          width={724}
          loading="lazy"
          decoding="async"
        />
      </figure>

      <div class="mt-16 flex justify-center md:mt-24">
        <a
          href={humanizacionContent.resolucion.href}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary inline-flex items-center gap-2 no-underline"
        >
          <Icon name="document" size={18} />
          {humanizacionContent.resolucion.label}
          <Icon name="external" size={14} />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
