---
import Icon from '@/components/icons/Icon.astro';
import LaboratorioClinicoHero from '@/components/sections/LaboratorioClinicoHero.astro';
import {
  laboratorioClinicoContent,
  laboratorioResultadosUrl,
} from '@/data/laboratorio-clinico';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Preparación para Exámenes"
  description="Preparaciones y recomendaciones para tomas de laboratorio clínico — EMCOSALUD."
>
  <LaboratorioClinicoHero
    title={laboratorioClinicoContent.title}
    lead={laboratorioClinicoContent.lead}
  />

  <section class="section-block">
    <div class="container-page max-w-4xl space-y-10">
      <div class="max-w-3xl">
        <p class="m-0 text-slate-700">{laboratorioClinicoContent.intro}</p>
        <p class="mt-4 text-sm italic text-slate-500">{laboratorioClinicoContent.disclaimer}</p>
      </div>

      <article class="rounded-2xl border border-brand-blue/15 bg-brand-blue/5 p-6">
        <h2 class="m-0 text-lg font-bold text-brand-blue">
          {laboratorioClinicoContent.resultsInfo.title}
        </h2>
        <div class="mt-3 space-y-3 text-sm leading-relaxed text-slate-700">
          {
            laboratorioClinicoContent.resultsInfo.paragraphs.map((paragraph) => (
              <p class="m-0">{paragraph}</p>
            ))
          }
        </div>
        <div class="mt-5 flex flex-wrap gap-3">
          <a
            href={laboratorioResultadosUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--primary inline-flex items-center gap-2 no-underline"
          >
            <Icon name="lab" size={18} />
            Consultar resultados
            <Icon name="external" size={14} />
          </a>
          <a
            href={laboratorioClinicoContent.resultsInfo.instructivoPdf}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--outline inline-flex items-center gap-2 no-underline"
          >
            <Icon name="document" size={18} />
            Instructivo de resultados
            <Icon name="external" size={14} />
          </a>
        </div>
      </article>

      <div>
        <h2 class="m-0 text-xl font-bold text-brand-blue">Preparaciones por examen</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            laboratorioClinicoContent.preparaciones.map((item) => (
              <article class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h3 class="m-0 text-base font-bold text-brand-blue">{item.title}</h3>
                <p class="mt-2 mb-4 flex-1 text-sm text-slate-600">{item.description}</p>
                <a
                  href={item.pdfHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-semibold text-brand-blue no-underline hover:text-brand-green-dark"
                >
                  <Icon name="document" size={16} />
                  Ver recomendaciones
                  <Icon name="external" size={14} class="opacity-60" />
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
