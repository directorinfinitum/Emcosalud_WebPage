---
import Icon from '@/components/icons/Icon.astro';
import AtencionUsuarioHero from '@/components/sections/AtencionUsuarioHero.astro';
import { atencionUsuarioAssets, mejoremosJuntosContent } from '@/data/atencion-usuario';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mejoremos Juntos"
  description="Sistema PQRSF — peticiones, quejas, reclamos, sugerencias y felicitaciones — EMCOSALUD."
>
  <AtencionUsuarioHero title={mejoremosJuntosContent.title} lead={mejoremosJuntosContent.lead} />

  <section class="section-block">
    <div class="container-page max-w-4xl space-y-10">
      <div>
        <h2 class="m-0 text-xl font-bold text-brand-blue">Tipos de requerimientos</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            mejoremosJuntosContent.types.map((type) => (
              <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="m-0 text-lg font-bold text-brand-blue">
                  {type.emoji} {type.title}
                </p>
                <p class="mt-2 mb-0 text-sm text-slate-600">{type.description}</p>
              </article>
            ))
          }
        </div>
      </div>

      <div>
        <h2 class="m-0 text-xl font-bold text-brand-blue">Canales de atención PQRSF</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {
            mejoremosJuntosContent.regions.map((region) => (
              <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h3 class="m-0 text-lg font-bold text-brand-blue">{region.name}</h3>

                <div class="mt-4 space-y-4">
                  {
                    region.offices.map((office) => (
                      <div class="rounded-xl border border-slate-100 bg-slate-50 p-4">
                        <p class="m-0 text-sm font-bold text-brand-blue">{office.city}</p>
                        <p class="mt-1 mb-0 flex items-start gap-2 text-sm text-slate-700">
                          <Icon name="location" size={16} class="mt-0.5 shrink-0 text-brand-green" />
                          {office.address}
                        </p>
                        <div class="mt-3">
                          <p class="m-0 flex items-center gap-2 text-xs font-bold uppercase tracking-wide text-brand-blue">
                            <Icon name="clock" size={14} class="text-brand-green" />
                            Horario de atención
                          </p>
                          <ul class="mb-0 mt-2 list-none space-y-1 p-0">
                            {
                              office.schedules.map((slot) => (
                                <li class="text-sm text-slate-600 before:mr-2 before:text-brand-green before:content-['•']">
                                  {slot}
                                </li>
                              ))
                            }
                          </ul>
                        </div>
                      </div>
                    ))
                  }
                </div>

                <div class="mt-4 space-y-2 border-t border-slate-100 pt-4 text-sm text-slate-700">
                  <p class="m-0">
                    <strong>Correo:</strong>{' '}
                    <a
                      href={region.email.href}
                      class="font-medium text-brand-blue no-underline hover:text-brand-green-dark"
                    >
                      {region.email.label}
                    </a>
                  </p>
                  <p class="m-0">
                    <strong>Teléfono:</strong>{' '}
                    <a
                      href={region.phone.href}
                      class="font-medium text-brand-blue no-underline hover:text-brand-green-dark"
                    >
                      {region.phone.label}
                    </a>
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <div class="rounded-2xl border border-brand-green/30 bg-brand-green/5 p-6">
        <h2 class="m-0 text-lg font-bold text-brand-blue">Guía del Paciente y su Familia</h2>
        <p class="mt-2 text-slate-700">
          Conoce tus derechos, deberes, procesos de atención y canales de comunicación.
        </p>
        <a
          href={atencionUsuarioAssets.derechosDeberesPdf}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary mt-4 inline-flex items-center gap-2 no-underline"
        >
          <Icon name="document" size={18} />
          Ver o descargar la guía
          <Icon name="external" size={14} />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
