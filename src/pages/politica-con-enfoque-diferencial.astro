---
import Icon from '@/components/icons/Icon.astro';
import AtencionUsuarioHero from '@/components/sections/AtencionUsuarioHero.astro';
import { politicaEnfoqueDiferencial } from '@/data/atencion-usuario';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Política con Enfoque Diferencial"
  description="Protocolos y resoluciones de atención con enfoque diferencial — EMCOSALUD."
>
  <AtencionUsuarioHero title={politicaEnfoqueDiferencial.title} lead={politicaEnfoqueDiferencial.lead} />

  <section class="section-block">
    <div class="container-page max-w-3xl space-y-4">
      {
        politicaEnfoqueDiferencial.documents.map((doc) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="m-0 text-lg font-bold text-brand-blue">{doc.title}</h2>
            <p class="mt-2 mb-0 text-sm text-slate-600">{doc.description}</p>
            <p class="mt-2 mb-0 text-xs font-semibold uppercase tracking-wide text-slate-500">
              Actualización: {doc.updated}
            </p>
            <a
              href={doc.href}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--primary mt-4 inline-flex items-center gap-2 no-underline"
            >
              <Icon name="document" size={18} />
              Descargar documento
              <Icon name="external" size={14} />
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
