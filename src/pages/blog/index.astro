---
import { blogPosts } from '@/data/services';
import BaseLayout from '@/layouts/BaseLayout.astro';

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-CO', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}
---

<BaseLayout title="Blog">
  <section class="section-block">
    <div class="container-page">
      <h1 class="section-title">Blog</h1>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          blogPosts.map((post) => (
            <article class="card-base">
              <time class="text-xs font-bold text-brand-green-dark" datetime={post.date}>
                {formatDate(post.date)}
              </time>
              <h2 class="my-2 text-lg font-bold">
                <a href={`/blog/${post.slug}`} class="text-brand-blue no-underline hover:text-brand-green-dark">
                  {post.title}
                </a>
              </h2>
              <p class="m-0 text-sm text-slate-600">{post.excerpt}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
